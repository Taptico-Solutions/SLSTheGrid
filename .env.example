# ──────────────────────────────────────────────────────────────────────────
# The GRID — environment variables
# ──────────────────────────────────────────────────────────────────────────

# Postgres (Supabase) — use the *transaction pooler* URL for serverless.
# Format: postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# For the SLS Grid project, find this under Supabase > Project Settings > Database.
DATABASE_URL=postgres://postgres:password@host:6543/postgres

# Supabase project — public values (safe to ship to the browser).
# SLS Grid (creftofevhtttzgmybjv): defaults below.
NEXT_PUBLIC_SUPABASE_URL=https://creftofevhtttzgmybjv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_2ofwx_CLEzy2xmlxBfd6kQ_9acpL5V1

# Supabase service role — SERVER ONLY. Bypasses RLS. Never expose.
# Grab from Supabase > Project Settings > API > Service role (secret).
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Storage bucket name. The May 2026 launch bucket is "documents".
SUPABASE_STORAGE_BUCKET=documents

# Public site URL (used for invite redirects). Required for admin.invite.
# Set to https://theslsgrid.com in prod, or the preview URL while testing.
GRID_PUBLIC_URL=https://theslsgrid.com

# OAuth — Open ID of the portal owner. This user is auto-promoted to "admin"
# on first sign-in. It is the Supabase `auth.users.id` (uuid). Optional.
OWNER_OPEN_ID=

# ── LLM (model-agnostic, switch by env) ──────────────────────────────────
# LLM_PROVIDER: anthropic | openai | openrouter
LLM_PROVIDER=anthropic
# Pick a specific model id for your provider:
#   anthropic:  claude-sonnet-4-6 | claude-opus-4-7 | claude-haiku-4-5-20251001
#   openai:     gpt-4o | gpt-4o-mini
#   openrouter: anthropic/claude-sonnet-4-6 | openai/gpt-4o | ...
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ── Legacy waitlist (preserved at /waitlist) ─────────────────────────────
GHL_API_KEY=
GHL_LOCATION_ID=Cvc5EmclHsFLw9BIuthx
